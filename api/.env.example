# Agent Console — Environment Configuration
# Copy to .env and adjust values. All variables use AC_ prefix.
# See api/app/config.py for defaults and types.

# ─── Required ──────────────────────────────────────────────
# PostgreSQL (async driver — must use asyncpg)
AC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/agent_console

# Redis (event bus, pub/sub, reconnect buffer)
AC_REDIS_URL=redis://redis:6379/0

# ─── OAuth (Claude Platform) ──────────────────────────────
AC_OAUTH_CLIENT_ID=your-client-id
AC_OAUTH_AUTHORIZE_URL=https://claude.ai/oauth/authorize
AC_OAUTH_TOKEN_URL=https://platform.claude.com/v1/oauth/token
AC_OAUTH_REDIRECT_URI=https://platform.claude.com/oauth/code/callback
AC_OAUTH_SCOPES=org:create_api_key user:profile user:inference user:sessions:claude_code user:mcp_servers

# ─── Optional ─────────────────────────────────────────────
# Agent workspace root (default: /workspace)
# AC_WORKSPACE_PATH=/workspace

# CORS origins (default: ["http://localhost:3000"])
# AC_CORS_ORIGINS=["http://localhost:3000"]

# Voyage AI embeddings (for memory/RAG — leave empty to disable)
# AC_VOYAGE_API_KEY=

# Circuit breaker (protects against cascading SDK failures)
# AC_CB_FAILURE_THRESHOLD=5       # failures before opening
# AC_CB_RECOVERY_TIMEOUT=30.0     # seconds before half-open
# AC_CB_FAILURE_WINDOW=60.0       # seconds to count failures

# Budget per session (USD)
# AC_BUDGET_SESSION_LIMIT_USD=2.0

# Git clone timeout for products (seconds)
# AC_CLONE_TIMEOUT_SECONDS=300

# MCP server → API base URL (for platform tools HTTP calls)
# AC_API_BASE_URL=http://localhost:8000
